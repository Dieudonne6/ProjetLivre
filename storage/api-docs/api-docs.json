        "/api/createlivre": {
            "post": {
                "tags": [
                    "Books"
                ],
                "summary": "Create a new book",
                "description": "Allow a seller to upload and publish a new book.",
                "operationId": "e5a865203ff0694114b7bb171f0d8750",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "nomL",
                                    "categorieL",
                                    "description",
                                    "path",
                                    "statutL",
                                    "date",
                                    "prixL"
                                ],
                                "properties": {
                                    "nomL": {
                                        "type": "string",
                                        "example": "The Art of Programming"
                                    },
                                    "categorieL": {
                                        "description": "Category ID",
                                        "type": "integer",
                                        "example": 2
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "A complete guide to modern programming concepts."
                                    },
                                    "path": {
                                        "description": "PDF file of the book",
                                        "type": "string",
                                        "format": "binary"
                                    },
                                    "statutL": {
                                        "description": "1 = published, 0 = draft",
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2026-03-22"
                                    },
                                    "prixL": {
                                        "type": "number",
                                        "example": 2500
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Book created successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "msg": {
                                            "type": "string",
                                            "example": "Book successfully created"
                                        },
                                        "book": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
